# ==============================
# DOMAIN — твой почтовый домен
# MX-запись должна указывать на IP этого сервера
# ==============================
DOMAIN=mail.example.com

# JWT секрет — смени на случайную строку!
JWT_SECRET=change-this-to-a-long-random-secret

# Порт для приёма входящей почты (SMTP)
# Порт 25 требует root или перенаправления: iptables -t nat -A PREROUTING -p tcp --dport 25 -j REDIRECT --to-port 2525
SMTP_PORT=25

# Порт REST API
API_PORT=3000

# Папка для хранения базы данных
DATA_DIR=/data

# ==============================
# SMTP-relay для исходящей почты
# Если пусто — отправка напрямую (порт 25 часто блокируют хостеры)
# Можно использовать Brevo, Mailgun, SendGrid и т.д.
# ==============================
SMTP_RELAY_HOST=
SMTP_RELAY_PORT=587
SMTP_RELAY_USER=
SMTP_RELAY_PASS=

# ==============================
# Первый пользователь (создаётся при npm run setup)
# ==============================
ADMIN_EMAIL=you@example.com
ADMIN_PASSWORD=changeme123

# ==============================
# Пароль для входа в админ-панель
# ==============================
ADMIN_PANEL_PASSWORD=admin-secret-change-me

# ==============================
# DNS-записи которые нужно настроить:
# MX  mail.example.com  →  IP_СЕРВЕРА  (приоритет 10)
# A   mail.example.com  →  IP_СЕРВЕРА
# TXT @  "v=spf1 mx ~all"
# ==============================
